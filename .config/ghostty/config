theme = Rose Pine
# theme = TokyoNight

shell-integration-features = no-cursor,no-sudo

# font (disable ligatures)
font-family = Dank Mono
font-size = 17
font-feature = -calt, -liga, -dlig
font-thicken = 1
font-thicken-strength = 1

# window
window-width = 114
window-height = 28
window-padding-x = 12
window-padding-y = 4

# cells (letter spacing, line height)
# set back to -1 if -3% doesn't make spacing consistent
# between built-in retina display and external monitor
adjust-cell-width = -3%
adjust-cell-height = 5
adjust-underline-position = 2

# mac specific settings
macos-titlebar-style = tabs
macos-icon = xray

# keybinds
keybind = option+c=esc:c

